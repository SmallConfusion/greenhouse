{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ControllerDesc",
    "type": "object",
    "properties": {
        "peripherals": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/PeripheralDesc"
            }
        },
        "stage_sets": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/StageSetDesc"
            }
        }
    },
    "required": [
        "peripherals",
        "stage_sets"
    ],
    "$defs": {
        "ConditionDesc": {
            "anyOf": [
                {
                    "$ref": "#/$defs/Range_of_float"
                }
            ]
        },
        "PeripheralDesc": {
            "anyOf": [
                {
                    "type": "array",
                    "maxItems": 2,
                    "minItems": 2,
                    "prefixItems": [
                        {
                            "type": "integer",
                            "format": "uint8",
                            "maximum": 255,
                            "minimum": 0
                        },
                        {
                            "$ref": "#/$defs/PinState"
                        }
                    ]
                },
                {
                    "type": "array",
                    "maxItems": 2,
                    "minItems": 2,
                    "prefixItems": [
                        {
                            "$ref": "#/$defs/VentDesc"
                        },
                        {
                            "$ref": "#/$defs/VentState"
                        }
                    ]
                }
            ]
        },
        "PinState": {
            "type": "string",
            "enum": [
                "Off",
                "On"
            ]
        },
        "Range_of_float": {
            "type": "object",
            "properties": {
                "end": {
                    "type": "number",
                    "format": "float"
                },
                "start": {
                    "type": "number",
                    "format": "float"
                }
            },
            "required": [
                "start",
                "end"
            ]
        },
        "SettingDesc": {
            "anyOf": [
                {
                    "$ref": "#/$defs/PinState"
                },
                {
                    "$ref": "#/$defs/VentState"
                }
            ]
        },
        "StageDesc": {
            "type": "object",
            "properties": {
                "condition": {
                    "$ref": "#/$defs/ConditionDesc"
                },
                "settings": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/SettingDesc"
                    }
                }
            },
            "required": [
                "settings",
                "condition"
            ]
        },
        "StageSetDesc": {
            "type": "object",
            "properties": {
                "stages": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/StageDesc"
                    }
                }
            },
            "required": [
                "stages"
            ]
        },
        "VentDesc": {
            "type": "object",
            "properties": {
                "off": {
                    "type": "integer",
                    "format": "uint8",
                    "maximum": 255,
                    "minimum": 0
                },
                "on": {
                    "type": "integer",
                    "format": "uint8",
                    "maximum": 255,
                    "minimum": 0
                }
            },
            "required": [
                "on",
                "off"
            ]
        },
        "VentState": {
            "type": "number",
            "format": "float"
        }
    }
}